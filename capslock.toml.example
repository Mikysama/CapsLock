# Copy to capslock.toml in the workspace when project-specific settings are needed.
[model]
# api_key is intentionally omitted: use CAPSLOCK_API_KEY or DEEPSEEK_API_KEY.
base_url = "https://api.deepseek.com"
model = "deepseek-v4-flash"
timeout_seconds = 60
max_turns = 6
max_context_messages = 24
command_timeout_seconds = 120
command_output_bytes = 100000
# Optional USD prices per million tokens for /cost.
input_cost_per_million = 0
output_cost_per_million = 0
