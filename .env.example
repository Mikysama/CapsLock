# This file is a template and is never loaded at runtime.
# Copy the settings you need to .env or export them in your shell.
# CAPSLOCK_API_KEY=your_api_key_here

# Optional external research credential:
# CAPSLOCK_TAVILY_API_KEY=your_tavily_api_key_here

# Optional OpenAI-compatible model settings:
# CAPSLOCK_BASE_URL=https://api.deepseek.com
# CAPSLOCK_MODEL=deepseek-v4-flash
# CAPSLOCK_MAX_TOOL_ROUNDS=32

# Routed providers read current credential references from config.toml:
# PRIMARY_MODEL_API_KEY=your_api_key_here
# BACKUP_MODEL_API_KEY=your_api_key_here

# Use credential = "env:NAME" or "keyring:NAME" in config.toml. Store keyring
# values with `capslock credentials set NAME`; never put secret values in TOML.

# CAPSLOCK_HOME and CAPSLOCK_MEMORY_DATABASE are shell-only absolute paths.
# Values placed in a project .env are intentionally ignored.
